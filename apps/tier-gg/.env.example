# ──────────────────────────────────────────────────────────────
# Tier.gg — 환경 변수 명세
# 실제 값은 .env.local (git ignore) 에 작성할 것
# ──────────────────────────────────────────────────────────────

# Supabase — 브라우저 공개 (anon key, RLS 적용)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase — 서버 전용 (service role key, RLS 우회, 절대 브라우저 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# 관리자 이메일 — 이 이메일로 로그인한 Supabase 사용자만 /api/admin 접근 허용
ADMIN_EMAIL=admin@example.com

# ──────────────────────────────────────────────────────────────
# 개발 / 빌드 옵션
# ──────────────────────────────────────────────────────────────

# Mock 데이터 강제 사용 — true면 Supabase 키가 있어도 mock-models.ts 사용
# (CI/스테이징/E2E 등 DB 미연결 환경에서 빌드/테스트 통과용)
# Supabase 키 누락 시에는 자동으로 mock 모드 진입.
USE_MOCK_DATA=false

# 사이트 URL (canonical, OG, sitemap 용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
