# ─── 툰일기 환경변수 예시 (복사 → .env.local) ───

# App
NEXT_PUBLIC_APP_URL=http://localhost:3003

# Supabase (Auth + DB + Storage)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Vertex AI — Gemini 2.5 Flash Image (Nano Banana), asia-northeast3
GCP_PROJECT_ID=
GCP_LOCATION=asia-northeast3
GOOGLE_APPLICATION_CREDENTIALS=
VERTEX_IMAGE_MODEL=gemini-2.5-flash-image

# OpenAI (백업 ImageProvider — gpt-image-1)
OPENAI_API_KEY=

# LLM (일기 4컷 분절)
LLM_PROVIDER=vertex
LLM_MODEL=gemini-2.5-flash

# Redis / Queue (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Toss Payments
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# 이미지 생성 정책
IMAGE_PROVIDER=vertex
COST_GUARD_MAX_PER_IMAGE_USD=0.05
