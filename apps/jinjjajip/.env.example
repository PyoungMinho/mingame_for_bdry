# 진짜집(Jinjjajip) 환경변수 예시
# Supabase (BaaS 코어: Auth / Postgres+PostGIS / Storage / Realtime)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# service role 키는 서버 전용. 클라이언트 번들에 절대 노출 금지(NEXT_PUBLIC_ 접두사 금지).
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
# Edge Functions 베이스 URL — photo-pipeline 트리거(POST /functions/v1)에 사용.
# 미설정 시 사진 업로드는 저장되나 파이프라인 트리거는 스킵(로컬 개발).
SUPABASE_FUNCTIONS_URL=https://YOUR-PROJECT.functions.supabase.co

# Storage 버킷(수동 생성 필요 — SQL/마이그레이션으로 생성 불가, Supabase 콘솔에서 생성):
#   - listing-photos-original : private (비공개. 원본 사진. 서명 URL로만 접근)
#   - listing-photos-blurred  : public  (공개. 블러 통과 승인본만 게시)

# 본인인증 (PASS / 통신사) — M0 PoC, 미설정 시 모의 게이트 사용
PASS_CLIENT_ID=
PASS_CLIENT_SECRET=

# 외부 ACL (등기/실거래) — M0 PoC, 미설정 시 pending 처리(0점 아님)
GOV_DATA_API_KEY=
REGISTRY_API_KEY=

# 앱
NEXT_PUBLIC_APP_URL=http://localhost:3002
