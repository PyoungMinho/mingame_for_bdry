# Team Makes 환경 변수
# 이 파일을 .env.local로 복사 후 실제 값을 입력하세요
# 절대 .env.local을 git에 커밋하지 마세요

# === MCP 연동 ===

# Figma Personal Access Token
FIGMA_ACCESS_TOKEN=

# Google Sheets Service Account Key (JSON 파일 경로)
GOOGLE_SERVICE_ACCOUNT_KEY=

# ============================================================
# 오름(Oreum) 백엔드 환경변수
# ============================================================

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
# 서버 전용 (절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Upstash Redis (레이트리밋 + AI 비용 카운터) ===
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# === AI API Keys (서버 전용) ===
ANTHROPIC_API_KEY=sk-ant-your-key
OPENAI_API_KEY=sk-your-openai-key

# === AI 예산 설정 (Q4 사장 확정: ₩200/유저/월) ===
AI_BUDGET_KRW_MONTHLY=200

# === 점수 산식 버전 (score_formula.md §6, §8) ===
# 코드 하드코딩 금지. v1 → v2 업그레이드 시 ENV로 전환
SCORE_FORMULA_VERSION=v1

# === 코치챗 무료 체험 (Q5 사장 결정: 가입 후 3일) ===
COACH_FREE_TRIAL_DAYS=3

# === KST 타임존 (체크인 일자 경계) ===
APP_TIMEZONE=Asia/Seoul

# === 결제 (W7~8 활성화) ===
TOSS_PAYMENTS_SECRET=test_sk_your-toss-secret
# RevenueCat (W18 앱 출시 시)
# REVENUECAT_API_KEY=your-revenuecat-key

# === 모니터링 ===
SENTRY_DSN=https://your-sentry-dsn
NEXT_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-key

# ============================================================
# 모이라(Moira) — 대중교통 공평 중간지점
# ============================================================
# 아래 2개가 "둘 다" 있으면 라이브 실계산(아무 주소나 진짜 대중교통 시간).
# 하나라도 없으면 자동으로 시드(프리셋 근사) 폴백 → 0원·무중단.

# 카카오 로컬 REST 키 (서버 전용, 주소→좌표 지오코딩) — developers.kakao.com
KAKAO_REST_KEY=
# ODsay 대중교통 길찾기 키 (서버 전용, 실경로·시간) — lab.odsay.com (Basic 무료: 1일 1,000/6개월)
ODSAY_API_KEY=
# (선택) 카카오맵 JS 키 — 지도 실타일. 없으면 SVG 폴백으로 데모 정상 동작
NEXT_PUBLIC_KAKAO_MAP_KEY=

# (선택) 공평 점수 가중치 — 기본 α=0.4 평균 / β=0.4 최대 / γ=0.2 표준편차
# MOIRA_SCORE_ALPHA=0.4
# MOIRA_SCORE_BETA=0.4
# MOIRA_SCORE_GAMMA=0.2
