    "concept": "심야의 스튜디오 (After-Hours Studio)",
    "version": 1,
    "sourceOfTruth": true,
    "note": "docs/design/office-design-final.md와 충돌 시 이 파일이 우선. 외부 이미지 에셋 0개, 전부 프로시저럴 Canvas 렌더."
  },
  "iso": {
    "tileW": 64,
    "tileH": 32,
    "originX": 720,
    "originY": 160,
    "wallHeight": 48,
    "deskHeight": 28,
    "projection": {
      "cartToIso": "x = originX + (gx - gy) * (tileW/2); y = originY + (gx + gy) * (tileH/2)",
      "isoToCart": "a=(sx-originX)/(tileW/2); b=(sy-originY)/(tileH/2); gx=(a+b)/2; gy=(b-a)/2"
    },
    "zSort": "renderOrder = gx + gy; 동률이면 layer 우선순위(floor<wall<desk<npc) 후 삽입순"
  },
