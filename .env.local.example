# 오후의 패 — 실시간 멀티(Supabase) 환경변수
# 이 파일을 복사해 `.env.local` 로 만들고 값을 채우세요. (.env.local 은 git에 올리지 마세요)
#
# Supabase 대시보드 → Project Settings → API 에서 확인:

# 공개 키 (브라우저 노출 OK)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-public-key...

# 비밀 키 (서버 전용 — 절대 클라이언트/깃에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-secret...
